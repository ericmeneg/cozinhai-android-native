<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".Search">

    <ImageView
        android:id="@+id/logo"
        android:layout_width="223dp"
        android:layout_height="50dp"
        android:layout_marginTop="46dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/logo" />

    <!-- Seletor de Tipo de Busca (Ingredientes / Título) -->
    <LinearLayout
        android:id="@+id/toggleLayout"
        android:layout_width="320dp"
        android:layout_height="48dp"
        android:layout_marginTop="32dp"
        android:background="@drawable/button_style"
        android:backgroundTint="#D9D9D9"
        android:orientation="horizontal"
        android:padding="2dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/logo">

        <Button
            android:id="@+id/btnByIngredient"
            style="@style/button"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Ingredientes"
            android:textAllCaps="false"
            android:textSize="14sp"
            android:insetTop="0dp"
            android:insetBottom="0dp" />

        <Button
            android:id="@+id/btnByTitle"
            style="@style/button"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:backgroundTint="@android:color/transparent"
            android:text="Título"
            android:textAllCaps="false"
            android:textColor="@color/gray200"
            android:textSize="14sp"
            android:insetTop="0dp"
            android:insetBottom="0dp" />
    </LinearLayout>

    <!-- Barra de Pesquisa Estilizada -->
    <LinearLayout
        android:id="@+id/searchBar"
        android:layout_width="340dp"
        android:layout_height="54dp"
        android:layout_marginTop="20dp"
        android:background="@drawable/card_style"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toggleLayout">

        <EditText
            android:id="@+id/editSearch"
            style="@style/text"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:hint="Insira os ingredientes"
            android:textColorHint="@color/gray100"
            android:textSize="14sp"
            android:inputType="text" />

        <ImageButton
            android:id="@+id/btnAddIcon"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginEnd="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_input_add"
            app:tint="@color/mainDarkBlue" />

        <ImageButton
            android:id="@+id/btnFilterIcon"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginEnd="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_filter"
            app:tint="@color/mainDarkBlue" />

        <Button
            android:id="@+id/btnSearchAction"
            style="@style/button"
            android:layout_width="wrap_content"
            android:layout_height="38dp"
            android:text="Pesquisar"
            android:textAllCaps="false"
            android:textSize="12sp"
            android:paddingHorizontal="12dp" />
    </LinearLayout>

    <TextView
        android:id="@+id/txtStatus"
        style="@style/h3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="60dp"
        android:text="Nenhum resultado encontrado"
        android:textSize="16sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/searchBar" />

    <!-- Barra de Navegação Inferior Customizada -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <View
            android:id="@+id/navBackground"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@color/mainDarkBlue"
            app:layout_constraintBottom_toBottomOf="parent" />

        <ImageButton
            android:id="@+id/btnNavHome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="16dp"
            android:src="@drawable/ic_home"
            app:layout_constraintBottom_toBottomOf="@id/navBackground"
            app:layout_constraintEnd_toStartOf="@+id/btnNavSearch"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/navBackground" />

        <ImageButton
            android:id="@+id/btnNavProfile"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="16dp"
            android:src="@drawable/ic_person"
            app:layout_constraintBottom_toBottomOf="@id/navBackground"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintStart_toEndOf="@+id/btnNavSearch"
            app:layout_constraintTop_toTopOf="@id/navBackground" />

        <ImageButton
            android:id="@+id/btnNavSearch"
            android:layout_width="44dp"
            android:layout_height="46dp"
            android:background="@drawable/bg_circle_white"
            android:elevation="4dp"
            android:padding="16dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_search_nav"
            tools:layout_editor_absoluteX="174dp"
            tools:layout_editor_absoluteY="21dp" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>